generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Product {
  id                      String        @id @default(cuid())
  sourcePlatform          String
  sourceProductId         String        @unique
  contentId               String?
  sourceStatus            String?
  titleSource             String
  titleEdited             String?
  descriptionSource       String?
  descriptionEdited       String?
  salePriceSource         Float?
  salePriceEdited         Float?
  listPriceSource         Float?
  deliveryDurationSource  Int?
  deliveryDurationEdited  Int?
  vatRateSource           Float?
  brand                   String?
  brandId                 Int?
  sku                     String?
  barcode                 String?
  categorySource          String?
  categoryId              Int?
  productMainId          String?
  cargoCompanyId          Int?
  shipmentAddressId       Int?
  returningAddressId      Int?
  status                  String        @default("draft")
  images                  ProductImage[]
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
}

model ProductImage {
  id             String   @id @default(cuid())
  productId      String
  sourceUrl      String
  localPath      String?
  downloadStatus String?  @default("remote")
  sortOrder      Int      @default(0)
  isSelected     Boolean  @default(true)
  createdAt      DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}